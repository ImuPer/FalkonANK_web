<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ 'invoice.title'|trans }} {{ invoiceNumber }}</title>

    <style>
        body { font-family: Arial, sans-serif; color: #111; }
        .header { text-align: center; margin-bottom: 30px; }
        .box { margin-bottom: 20px; }
        h1 { color: #1db954; }
    </style>
</head>

<body>

<div class="header">
    <h1>{{ 'invoice.invoice'|trans }}</h1>
    <p>{{ 'invoice.number'|trans }} {{ invoiceNumber }}</p>
</div>

<div class="box">
    <h3>{{ 'invoice.customer'|trans }}</h3>
    <p>
        {{ customerName }}<br>
        {{ customerEmail }}<br>
        {{ customerPhone }}
    </p>
</div>

<div class="box">
    <h3>{{ 'invoice.album'|trans }}</h3>
    <p>
        <strong>{{ albumName }}</strong><br>
        {{ 'invoice.label'|trans }} {{ recordLabel }}<br>
        {{ 'invoice.date'|trans }} {{ releaseDate|date('d/m/Y') }}
    </p>
</div>

<div class="box">
    <h3>{{ 'invoice.payment'|trans }}</h3>
    <p>
        {{ 'invoice.amount'|trans }} <strong>{{ amountPaid }} {{ currency }}</strong><br>
        {{ 'invoice.stripe_id'|trans }} {{ paymentIntent }}
    </p>
</div>

<div class="box">
    <h3>FalkonANK</h3>
</div>

</body>
</html>
