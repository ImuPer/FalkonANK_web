/* =========================
   STOP SESSION
========================= */
async function stopMusicSession() {
    if (!musicToken) return;

    try {
        await fetch('/music/session/stop', {
            method: 'POST',
            headers: {
                'X-Music-Token': musicToken,
                'Content-Type': 'application/json'
            },
            keepalive: true
        });

        localStorage.removeItem('music_token');
        musicToken = null;

    } catch (e) {
        console.error('Stop session error', e);
    }
}

{% if app.user %}
	setInterval(async () => {
