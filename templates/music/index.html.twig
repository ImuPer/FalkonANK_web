{# templates/music/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}🎵 Album - {{ product.name }}{% endblock %}

{% block body %}

<style>
.album-header {
    text-align: center;
    margin: 40px 0;
}

.album-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    padding: 20px;
}

.music-card {
    background: #111;
    border-radius: 15px;
    padding: 15px;
    color: white;
    box-shadow: 0 0 15px rgba(0,0,0,0.3);
    transition: 0.3s;
}

.music-card:hover {
    transform: translateY(-5px);
}

.music-title {
    font-size: 18px;
    margin-bottom: 5px;
}

.music-artist {
    font-size: 14px;
    color: #aaa;
    margin-bottom: 10px;
}

audio {
    width: 100%;
    outline: none;
}

.cover {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 10px;
}
</style>

<div class="album-header">
    <h1>💿 {{ product.name }}</h1>
    <p>{{ product.description }}</p>
</div>

<div class="album-grid">

    {% for music in musics %}

        <div class="music-card">

            {% if music.coverImage %}
                <img class="cover"
                     src="{{ asset('uploads/images/' ~ music.coverImage) }}"
                     alt="cover">
            {% endif %}

            <div class="music-title">
                🎵 {{ music.title }}
            </div>

            <div class="music-artist">
                {{ music.artist }}
            </div>

            <audio controls loop>
                <source src="{{ asset('uploads/music/' ~ music.audioFile) }}"
                        type="audio/mpeg">
            </audio>

        </div>

    {% else %}

        <p style="text-align:center;">Aucune musique disponible 🎧</p>

    {% endfor %}

</div>

{% endblock %}