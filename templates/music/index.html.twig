{# templates/music/index.html.twig #}

{% extends 'base.html.twig' %}

{% set pageTitle = album is defined ? album.name : product.name %}
{% set coverImage = album is defined ? asset('uploads/albums/' ~ album.coverImage) : asset('upload/images/products/' ~ product.img) %}

{% block title %}🎵 {{ 'music.album'|trans }} -
	{{ pageTitle }}
{% endblock %}

{% block body %}

	<style>

		body {
			background: #0b0b0b;
			color: white;
			margin: 0;
			padding: 0;
			font-family: Arial, Helvetica, sans-serif;
		}

		/* =========================
   HEADER
========================= */

		.album-header {
			text-align: center;
			padding: 40px 20px;
		}

		.album-header h1 {
			font-size: clamp(30px, 5vw, 55px);
			margin-bottom: 10px;
		}

		.album-header h2 {
			color: #aaa;
			font-weight: 300;
		}

		/* =========================
   ZOOM COVER
========================= */

		.album-header h2 {
			cursor: pointer;
			transition: 0.3s;
		}

		.album-header h2:hover {
			transform: scale(1.05);
			color: #1db954;
		}

		.cover-modal {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.95);
			display: none;
			justify-content: center;
			align-items: center;
			z-index: 99999;
			backdrop-filter: blur(8px);
			animation: fadeIn 0.3s ease;
		}

		.cover-modal img {
			max-width: 90%;
			max-height: 90vh;
			border-radius: 20px;
			box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
			animation: zoomCover 0.3s ease;
			object-fit: cover;
		}

		.close-cover {
			position: absolute;
			top: 20px;
			right: 30px;
			font-size: 35px;
			color: white;
			cursor: pointer;
			z-index: 2;
			transition: 0.3s;
		}

		.close-cover:hover {
			color: #1db954;
			transform: scale(1.2);
		}

		@keyframes zoomCover {
			from {
				transform: scale(0.7);
				opacity: 0;
			}
			to {
				transform: scale(1);
				opacity: 1;
			}
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
			}
			to {
				opacity: 1;
			}
		}

		/* =========================
   GLOBAL PLAYER
========================= */

		.global-player {
			position: sticky;
			top: 0;
			z-index: 999;
			background: #111;
			border-bottom: 1px solid #222;
			padding: 15px;
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: center;
			gap: 15px;
		}

		.global-player button {
			background: #1db954;
			border: none;
			color: white;
			width: 50px;
			height: 50px;
			border-radius: 50%;
			cursor: pointer;
			font-size: 20px;
			transition: 0.3s;
		}

		.global-player button:hover {
			transform: scale(1.1);
		}

		.now-playing {
			font-size: 16px;
			color: #fff;
			min-width: 200px;
			text-align: center;
		}

		#main-player {
			width: 100%;
			max-width: 500px;
		}

		/* =========================
   GRID
========================= */

		.album-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			gap: 30px;
			padding: 30px;
			max-width: 1400px;
			margin: auto;
		}

		/* =========================
   CARD
========================= */

		.music-card {
			background: #111;
			border-radius: 20px;
			padding: 20px;
			text-align: center;
			transition: 0.3s;
			box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
		}

		.music-card:hover {
			transform: translateY(-5px);
		}

		/* =========================
   CD
========================= */

		.cd-wrapper {
			width: 220px;
			height: 220px;
			margin: auto;
		}

		.cd-disc {
			width: 100%;
			height: 100%;
			border-radius: 50%;
			overflow: hidden;
			position: relative;
			background: black;
			box-shadow: 0 0 20px rgba(0, 0, 0, 0.6), inset 0 0 15px rgba(255, 255, 255, 0.1);
		}

		.cd-disc.playing {
			animation: spin 5s linear infinite;
		}

		.cd-disc img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			border-radius: 50%;
		}

		.cd-disc::after {
			content: "";
			position: absolute;
			top: 50%;
			left: 50%;
			width: 40px;
			height: 40px;
			transform: translate(-50%, -50%);
			background: #111;
			border: 5px solid #444;
			border-radius: 50%;
		}

		/* =========================
   TEXT
========================= */

		.music-title {
			margin-top: 20px;
			font-size: 22px;
			font-weight: bold;
		}

		.music-artist {
			color: #aaa;
			margin-top: 5px;
			margin-bottom: 15px;
		}

		/* =========================
   BUTTON
========================= */

		.play-btn {
			background: #1db954;
			color: white;
			border: none;
			padding: 10px 18px;
			border-radius: 30px;
			cursor: pointer;
			transition: 0.3s;
		}

		.play-btn:hover {
			background: #18a349;
		}

		.locked-btn {
			background: #444;
		}

		.locked-btn:hover {
			background: #555;
		}

		/* =========================
   RESPONSIVE
========================= */

		{# @media(max-width:768px) {

			.cd-wrapper {
				width: 150px;
				height: 150px;
			}

			.album-grid {
				padding: 15px;
			}

		} #}

		/* =========================
   SPIN
========================= */

		@keyframes spin {
			from {
				transform: rotate(0deg);
			}
			to {
				transform: rotate(360deg);
			}
		}

		/* =========================
   LYRICS BUTTON
========================= */

		.lyrics-btn {
			margin-top: 12px;
			background: #222;
			border: none;
			color: white;
			width: 45px;
			height: 45px;
			border-radius: 50%;
			cursor: pointer;
			font-size: 20px;
			transition: 0.3s;
		}

		.lyrics-btn:hover {
			background: #1db954;
			transform: scale(1.1);
		}

		.lyrics-text {
			white-space: pre-line;
			line-height: 1.8;
			color: #ddd;
			font-size: 18px;

			/* anti copie */
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;

			-webkit-touch-callout: none;
		}

		/* =========================
   MODAL LYRICS
========================= */

		.lyrics-modal {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.9);
			display: none;
			justify-content: center;
			align-items: center;
			z-index: 5000;
			padding: 20px;
		}

		.lyrics-content {
			background: #111;
			width: min(700px, 95%);
			max-height: 85vh;
			overflow-y: auto;
			border-radius: 20px;
			padding: 30px;
			box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
			position: relative;
			animation: zoomIn 0.3s ease;
		}

		.lyrics-content h2 {
			margin-top: 0;
			margin-bottom: 20px;
			text-align: center;
		}

		.lyrics-text {
			white-space: pre-line;
			line-height: 1.8;
			color: #ddd;
			font-size: 18px;
		}

		.close-lyrics {
			position: absolute;
			top: 15px;
			right: 20px;
			font-size: 28px;
			cursor: pointer;
			color: white;
		}

		.close-lyrics:hover {
			color: #1db954;
		}

		@keyframes zoomIn {
			from {
				transform: scale(0.7);
				opacity: 0;
			}
			to {
				transform: scale(1);
				opacity: 1;
			}
		}

		.music-card.active {
			border: 2px solid #1db954;
			box-shadow: 0 0 25px rgba(29, 185, 84, 0.5);
		}

		.album-header {
			text-align: center;
			padding: 100px 20px;
			position:relative;
			z-index:0;
			overflow:visible;
			background-image: url("{{ coverImage }}");
			background-size: cover;
			background-position: center;
			background-repeat: no-repeat;
			border-radius: 0 0 30px 30px;
		}
		.album-header::before {
			content: "";
			position: absolute;
			inset: 0;
			background: rgba(0, 0, 0, 0.55);
		}
		.album-header h1,
		.album-header h2 {
			position: relative;
			z-index: 2;
			color: white;
		}

		.album-header {
			position: relative;
			z-index: 1;
		}

		.album-header::before {
			z-index: 1;
		}

		.album-header h1,
		.album-header h2,
		.album-header a,
		.album-header div {
			position: relative;
			z-index: 2;
		}
		
		.album-info {
		color: #cbd5e1;
		margin-bottom: 10px;
		font-size: 0.95rem;
		}

		.album-date {
			color: #94a3b8;
			font-size: 0.9rem;
		}
		
		.buy-btn{
			display:inline-block;
			padding:15px 25px;
			background:#1db954;
			color:white;
			text-decoration:none;
			border-radius:12px;
			font-weight:bold;
			transition:.3s;
		}

		.buy-btn:hover{
			transform:scale(1.05);
			background:#18a349;
			color:white;
		}
		
		.repeat-active{
			background:#18a349 !important;
			box-shadow:0 0 15px #dbea0d;
		}

		.zoomable-cover{
			cursor:pointer;
			transition:.3s;
		}

		.zoomable-cover:hover{
			transform:scale(1.03);
			box-shadow:0 0 25px rgba(29,185,84,.4);
		}
		
		.shuffle-active{
			background:#18a349 !important;
			box-shadow:0 0 15px #00d9ff;
		}

		.album-btn{
			margin-left: 10px;
			background:#222;
			color:white;
			border:none;
			width:45px;
			height:45px;
			border-radius:50%;
			cursor:pointer;
			font-size:18px;
			transition:.3s;
		}

		.album-btn:hover{
			background:#1db954;
			transform:scale(1.1);
		}
		
		.back-albums-btn{
			display:inline-block;
			padding:10px 20px;
			background:#222;
			color:white;
			text-decoration:none;
			border-radius:12px;
			transition:.3s;
		}

		.back-albums-btn:hover{
			background:#1db954;
			color:white;
		}

		{# --------Modo Mobile---------------------- #}
		@media (max-width: 768px) {

			.album-header {
				padding: 35px 10px;
			}

			.album-header h2 {
				font-size: 20px;
				margin-bottom: 8px;
			}

			.album-info,
			.album-date {
				font-size: 0.8rem;
			}
		}

		@media (max-width: 768px) {

			.global-player {
				padding: 8px;
				gap: 8px;
			}

			.global-player button {
				width: 35px;
				height: 35px;
				font-size: 16px;
			}

			.now-playing {
				font-size: 13px;
				min-width: auto;
				width: 100%;
				order: -1; /* titre au-dessus des boutons */
			}

			#main-player {
				max-width: 100%;
				width: 100%;
			}

			.global-player a {
				font-size: 12px;
			}
		}
		
		@media (max-width: 768px) {

			.music-card {
				padding: 8px;
				border-radius: 12px;
			}

			.cd-wrapper {
				width: 200px;
				height: 200px;
			}

			.cd-disc::after {
				width: 22px;
				height: 22px;
				border-width: 2px;
			}

			.music-title {
				margin-top: 5px;
				font-size: 15px;
				line-height: 1.2;
			}

			.music-artist {
				font-size: 12px;
				margin: 4px 0 8px;
			}

			.play-btn {
				padding: 6px 10px;
				font-size: 12px;
			}

			.lyrics-btn,
			.album-btn {
				width: 32px;
				height: 32px;
				font-size: 13px;
			}

			.album-grid {
				gap: 10px;
				padding: 8px;
			}
		}
	</style>

	{# =========================
																	   USER STATUS
																	========================= #}

	{# {% set canPlayFull = hasBought %} #}
	{# {% set canPlayFull = hasBought or isFreeTrack %} #}

	{# =========================
																	   HEADER
																	========================= #}
	<div class="album-header">

		<h2>💿 {{ pageTitle }}</h2>
		<div	class="album-info">
			<p>
				{{ album.description|raw }}
			</p>
			<span>
				📀
				{{ album.recordLabel }}
			</span>
		</div>
		<div	class="album-date">
			{{ 'albums.release_date'|trans }}
			:
			{{ album.releaseDate|date('d/m/Y') }}
		</div>
		{% if app.user and not hasBought %}
			<div style="margin-top:20px; position:relative; z-index:2;">
				<a href="{{ path('app_album_buy', {id: album.id}) }}"
				class="btn btn-success">
					🛒 {{ 'music.buy_album'|trans }}
				</a>
			</div>
		{% endif %}
		{% if app.user and hasBought and purchase and purchase.invoiceNumber %}
			<div style="margin-top:15px;">
				<a href="{{ path('app_invoice_download', {
					id: purchase.id
				}) }}"
				class="buy-btn">
					📄 download {{ 'invoice.title'|trans }}
					{# Télécharger ma facture #}
				</a>
			</div>
		{% endif %}

		<div style="margin-top:15px; font-size:13px;">
			<a href="{{ path('app_albums_index') }}" class="back-albums-btn">
				← {{ 'albums.all_albums'|trans }}
			</a>
		</div>

	</div>

	<div class="cover-modal" id="coverModal">
		<span class="close-cover" id="closeCover">✖</span>
		<img src="{{ coverImage }}" alt="{{ pageTitle }}" id="zoomedCover">
	</div>

	{# =========================
																	   GLOBAL PLAYER
																	========================= #}

	<div class="global-player">

		<button id="prevBtn">⏮</button>

		<button id="playPauseBtn">▶</button>

		<button id="nextBtn">⏭</button>

		<button id="shuffleBtn">🔀</button>

		<button id="repeatBtn">🔂</button>
		<div class="now-playing" id="nowPlaying">
			{{ 'music.no_track'|trans }}
		</div>

		{# <audio id="main-player" controls></audio> #}
		{# <audio id="main-player" controls controlsList="nodownload"></audio> #}
		<audio id="main-player" controls controlslist="nodownload noplaybackrate" disablepictureinpicture></audio>

		{% if app.user and not hasBought %}
			<a href="{{ path('app_album_buy', {id: album.id}) }}" style="color:white"
			title="{{ 'music.buy_album'|trans }}">
				🛒 
			</a>
		{% endif %}
		{# ---------facture------------------ #}
		{% if app.user and hasBought and purchase and purchase.invoiceNumber %}					
			<a href="{{ path('app_invoice_download', { id: purchase.id }) }}"
				title="download {{ 'invoice.title'|trans }}">
				📄
			</a>
		{% endif %}

		<div >
			<a style="font-size:10px; color:white;" href="{{ path('app_albums_index') }}" title="{{ 'albums.all_albums'|trans }}">
				← {{ 'albums.all_albums'|trans }}
			</a>
		</div>
	</div>


	{# =========================
																				   ALBUM GRID
																				========================= #}

	<div class="album-grid">

		{% for music in musics %}

			{# 
																																																						       RÈGLES :
																																																						       - connecté => accès total
																																																						       - non connecté :
																																																						           * 2 premiers morceaux = complet
																																																						           * reste = seulement 60 secondes
																																																						    #}

			{% set isFreeTrack = loop.index0 < 2 %}
			{% set canPlayFullTrack = hasBought or isFreeTrack %}
			<div class="music-card" id="card-{{ loop.index0 }}">

				<div class="cd-wrapper">

					<div class="cd-disc zoomable-cover"
					id="disc-{{ loop.index0 }}"
					data-image="
					{% if music.coverImage %}
						{{ asset('uploads/images/' ~ music.coverImage) }}
					{% elseif music.album and music.album.coverImage %}
						{{ asset('uploads/albums/' ~ music.album.coverImage) }}
					{% else %}
						{{ asset('images/default-music.jpg') }}
					{% endif %}
					">
						{% if music.coverImage %}
							<img src="{{ asset('uploads/images/' ~ music.coverImage) }}" alt="{{ music.title }}">
						{% elseif music.album and music.album.coverImage %}
							<img src="{{ asset('uploads/albums/' ~ music.album.coverImage) }}" alt="{{ music.title }}">
						{% else %}
							<img src="{{ asset('images/default-music.jpg') }}" alt="default">
						{% endif %}

					</div>

				</div>

				<div class="music-title">
					{{ music.track }} <br> {{ music.title }}
				</div>

				<div class="music-artist">
					{{ music.artist }}
				</div>

				{# <div class="music-views">
					👁
					{{ music.views }}
					{{ 'music.views'|trans }}
				</div> #}

				<button class="play-btn {% if not canPlayFullTrack %}locked-btn{% endif %}"
					data-id="{{ music.id }}"
					data-src="{{ asset('uploads/music/' ~ music.audioFile) }}"
					data-title="{{ music.title }}"
					data-index="{{ loop.index0 }}"
					data-full="{{ canPlayFullTrack ? '1' : '0' }}">

					{% if app.user %}
						▶ {{ 'music.play'|trans }}
					{% else %}
						{% if isFreeTrack %}
							▶ {{ 'music.play'|trans }}
						{% else %}
							<a href="{{ path('app_login', {
								_target_path: app.request.uri
							}) }}">
								🔒 {{ 'music.login_to_listen'|trans }}
							</a>
						{% endif %}
					{% endif %}

				</button>

				<button class="lyrics-btn" data-lyrics="{{ music.lyrics|e('html_attr') }}" data-title="{{ music.title }}">
					🎤
				</button>

				<button class="album-btn"
					data-image="
					{% if music.coverImage %}
						{{ asset('uploads/images/' ~ music.coverImage) }}
					{% elseif music.album and music.album.coverImage %}
						{{ asset('uploads/albums/' ~ music.album.coverImage) }}
					{% else %}
						{{ asset('images/default-music.jpg') }}
					{% endif %}
				">
					💿
				</button>

			</div>

		{% endfor %}

	</div>

	<div class="lyrics-modal" id="lyricsModal">

		<div class="lyrics-content">

			<span class="close-lyrics" id="closeLyrics">
				✖
			</span>

			<h2 id="lyricsTitle">
				{{ 'music.lyrics'|trans }}
			</h2>

			<div class="lyrics-text"
				id="lyricsText"
				oncontextmenu="return false">
			</div>

		</div>

	</div>

	<script>

const repeatBtn = document.getElementById('repeatBtn');
const shuffleBtn = document.getElementById('shuffleBtn');
let musicToken = localStorage.getItem('music_token') || null;
let shuffleMode = false;
let repeatMode = false;
const player = document.getElementById('main-player');
const playPauseBtn = document.getElementById('playPauseBtn');
const nextBtn = document.getElementById('nextBtn');
const prevBtn = document.getElementById('prevBtn');
const nowPlaying = document.getElementById('nowPlaying');
const tracks = document.querySelectorAll('.play-btn');
let currentIndex = 0;

/* =========================
    SESSION
========================= */
async function startMusicSession() {

    try {

        console.log("Ancien token :", musicToken);

        const res = await fetch('/music/session/start', {
			method: 'POST',
			credentials: 'same-origin',
			headers: {
				'X-Music-Token': musicToken ?? '',
				'Content-Type': 'application/json'
			}
		});

        const data = await res.json();

        console.log(data);

        if (!data.success) {
            alert(data.message ?? "Impossible de démarrer la session.");
            return;
        }

        musicToken = data.token;

        localStorage.setItem('music_token', musicToken);

        console.log("Nouveau token :", musicToken);

        if (data.already_active) {
            alert(
                "Une autre session était active sur " +
                (data.device ?? "un autre appareil") +
                ". Elle a été déconnectée."
            );
        }

    } catch (e) {
        console.error(e);
    }

}

/* =========================
   REPEAT MODE
========================= */

repeatBtn.addEventListener('click', () => {

	repeatMode = !repeatMode;

	// repeat natif HTML5
	player.loop = repeatMode;

	if(repeatMode){

		repeatBtn.classList.add('repeat-active');

	}else{

		repeatBtn.classList.remove('repeat-active');

	}

});

/* =========================
   LOAD TRACK
========================= */

function loadTrack(index) {

const track = tracks[index];

player.src = track.dataset.src;

nowPlaying.innerHTML = "🎵 " + track.dataset.title;

currentIndex = index;

updateDiscs();

scrollToCurrentCard();

}

/* =========================
   AUTO SCROLL ACTIVE CARD
========================= */

function scrollToCurrentCard() { // retire ancienne active
document.querySelectorAll('.music-card').forEach(card => {
card.classList.remove('active');
});

// récupère la card actuelle
const activeCard = document.getElementById('card-' + currentIndex);

if (activeCard) { // active style
activeCard.classList.add('active');

// scroll vers la card
activeCard.scrollIntoView({behavior: 'smooth', block: 'center'});

}

}

/* =========================
   PLAY TRACK
========================= */

tracks.forEach(track => {

track.addEventListener('click', () => {

currentIndex = parseInt(track.dataset.index);

loadTrack(currentIndex);

player.play();

});

});

/* =========================
   PLAY / PAUSE
========================= */

playPauseBtn.addEventListener('click', () => {

if (player.paused) {

player.play();

} else {

player.pause();

}

});

/* =========================
   PLAYER EVENTS
========================= */

player.addEventListener('play', () => {

playPauseBtn.innerHTML = '⏸';

updateDiscs(true);

});

player.addEventListener('pause', () => {

playPauseBtn.innerHTML = '▶';

updateDiscs(false);

});

/* =========================
   LIMIT 60s FOR GUESTS
========================= */

player.addEventListener('timeupdate', () => {

const currentTrack = tracks[currentIndex];
const musicId = currentTrack.dataset.id;

// compter une seule vue
if (player.currentTime >= 5 && !viewedTracks.includes(musicId)) {

viewedTracks.push(musicId);

console.log("startMusicSession");

fetch('/music/' + musicId + '/view', {method: 'POST'});
}

const fullAccess = currentTrack.dataset.full === "1";

if (!fullAccess && player.currentTime >= 60) {
    player.pause();

	stopMusicSession();
    
	const isLogged = {{ app.user ? 'true' : 'false' }};

    if (!isLogged) {
        window.location.href =
		"{{ path('app_login') }}?_target_path=" +
		encodeURIComponent(window.location.pathname + window.location.search);
    } else {
        if (confirm("{{ 'music.confirm_buy'|trans }}\n {{ 'music.confirm_buy2'|trans|lower }}")) {
            window.location.href = "{{ path('app_album_buy', {id: album.id}) }}";
        }
    }
}

});

/* =========================
   NEXT
========================= */

nextBtn.addEventListener('click', () => {

if(shuffleMode){

	currentIndex = getRandomTrackIndex();

}else{

	currentIndex++;

	if (currentIndex >= tracks.length) {
		currentIndex = 0;
	}

}

loadTrack(currentIndex);

player.play();

});

/* =========================
   PREV
========================= */

prevBtn.addEventListener('click', () => {

currentIndex--;

if (currentIndex < 0) {
currentIndex = tracks.length - 1;
}

loadTrack(currentIndex);

player.play();

});

/* =========================
   AUTO NEXT
========================= */

player.addEventListener('ended', () => {


	// musique suivante
	if(shuffleMode){

		currentIndex = getRandomTrackIndex();

	}else{

		currentIndex++;

		if(currentIndex >= tracks.length){
			currentIndex = 0;
		}

	}

	loadTrack(currentIndex);

	player.play();

});

/* =========================
   DISC ANIMATION
========================= */

function updateDiscs(play = false) {

document.querySelectorAll('.cd-disc').forEach(disc => {
disc.classList.remove('playing');
});

if (play) {

const activeDisc = document.getElementById('disc-' + currentIndex);

if (activeDisc) {
activeDisc.classList.add('playing');
}

}

}

