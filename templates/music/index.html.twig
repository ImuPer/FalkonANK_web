```twig
{# templates/music/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}🎵 Album - {{ product.name }}{% endblock %}

{% block body %}

<style>

body{
    background:#0b0b0b;
}

/* =========================
   HEADER
========================= */

.album-header{
    text-align:center;
    padding:40px 20px 10px;
    color:white;
}

.album-header h1{
    font-size:clamp(28px,5vw,50px);
    font-weight:800;
    margin-bottom:10px;
}

.album-header h2{
    color:#bbb;
    font-size:18px;
    letter-spacing:2px;
}

/* =========================
   GRID
========================= */

.album-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:35px;
    padding:30px;
    max-width:1400px;
    margin:auto;
}

/* =========================
   CARD
========================= */

.music-card{
    background:linear-gradient(145deg,#1b1b1b,#101010);
    border-radius:25px;
    padding:25px;
    text-align:center;
    color:white;
    box-shadow:
        0 10px 30px rgba(0,0,0,0.5),
        inset 0 0 15px rgba(255,255,255,0.03);
    transition:0.3s;
    overflow:hidden;
}

.music-card:hover{
    transform:translateY(-8px);
}

/* =========================
   CD
========================= */

.cd-wrapper{
    width:220px;
    height:220px;
    margin:auto;
    position:relative;
}

.cd-disc{
    width:100%;
    height:100%;
    border-radius:50%;
    overflow:hidden;
    position:relative;

    background:
        radial-gradient(circle at center,
        #222 0%,
        #000 60%,
        #111 100%);

    box-shadow:
        0 0 25px rgba(0,0,0,0.7),
        inset 0 0 20px rgba(255,255,255,0.1);

    transition:0.3s;
}

/* rotation uniquement quand musique joue */
.cd-disc.playing{
    animation:spin 5s linear infinite;
}

.cd-disc img{
    width:100%;
    height:100%;
    object-fit:cover;
    border-radius:50%;
}

/* trou CD */
.cd-disc::after{
    content:"";
    position:absolute;
    top:50%;
    left:50%;
    width:45px;
    height:45px;
    transform:translate(-50%,-50%);
    border-radius:50%;
    background:#111;
    border:5px solid #444;
    z-index:10;
}

/* reflet */
.cd-disc::before{
    content:"";
    position:absolute;
    top:0;
    left:-40%;
    width:60%;
    height:100%;
    background:rgba(255,255,255,0.08);
    transform:skewX(-20deg);
    z-index:5;
}

/* =========================
   TEXT
========================= */

.music-title{
    margin-top:25px;
    font-size:22px;
    font-weight:700;
}

.music-artist{
    color:#aaa;
    margin-top:5px;
    margin-bottom:18px;
    font-size:15px;
}

/* =========================
   PLAYER
========================= */

audio{
    width:100%;
    border-radius:30px;
    margin-top:10px;
}

/* =========================
   RESPONSIVE
========================= */

@media(max-width:768px){

    .album-grid{
        padding:15px;
        gap:25px;
    }

    .music-card{
        padding:20px;
    }

    .cd-wrapper{
        width:180px;
        height:180px;
    }

}

/* =========================
   ANIMATION
========================= */

@keyframes spin{
    from{
        transform:rotate(0deg);
    }
    to{
        transform:rotate(360deg);
    }
}

</style>

<div class="album-header">

    <h1>🎵 {{ product.name }}</h1>

    <h2>💿 Album Musical</h2>

</div>

<div class="album-grid">

    {% for music in musics %}

        <div class="music-card">

            <div class="cd-wrapper">

                <div class="cd-disc" id="disc-{{ loop.index }}">

                    {% if music.coverImage %}
                        <img
                            src="{{ asset('uploads/images/' ~ music.coverImage) }}"
                            alt="{{ music.title }}"
                        >
                    {% else %}
                        <img
                            src="{{ asset('images/default-music.jpg') }}"
                            alt="default"
                        >
                    {% endif %}

                </div>

            </div>

            <div class="music-title">
                {{ music.title }}
            </div>

            <div class="music-artist">
                {{ music.artist }}
            </div>

            <audio
                controls
                loop
                class="music-player"
                data-disc="disc-{{ loop.index }}"
            >
                <source
                    src="{{ asset('uploads/music/' ~ music.audioFile) }}"
                    type="audio/mpeg"
                >
            </audio>

        </div>

    {% else %}

        <div style="color:white;text-align:center;width:100%;">
            🎧 Aucune musique disponible
        </div>

    {% endfor %}

</div>

<script>

document.querySelectorAll('.music-player').forEach(player => {

    const discId = player.dataset.disc;
    const disc = document.getElementById(discId);

    // quand play
    player.addEventListener('play', () => {
        disc.classList.add('playing');
    });

    // quand pause
    player.addEventListener('pause', () => {
        disc.classList.remove('playing');
    });

    // quand musique finie
    player.addEventListener('ended', () => {
        disc.classList.remove('playing');
    });

});

</script>

{% endblock %}
