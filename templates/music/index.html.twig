			const res = await fetch('/music/session/check', {
				headers: {
					'X-Music-Token': musicToken
				}
			});

			const data = await res.json();

			if (!data.active) {
				player.pause();
				localStorage.removeItem('music_token');
				alert("Votre session a été ouverte sur un autre appareil.");
				location.reload();
			}
		} catch (e) {
			console.error(e);
		}
	}, 15000);
