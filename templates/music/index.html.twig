{# templates/music/index.html.twig #}

{% extends 'base.html.twig' %}

{% set pageTitle = album is defined ? album.name : product.name %}
{% set coverImage = album is defined ? asset('uploads/albums/' ~ album.coverImage) : asset('upload/images/products/' ~ product.img) %}

{% block title %}🎵 {{ 'music.album'|trans }} -
	{{ pageTitle }}
{% endblock %}

{% block body %}

	<style>

		body {
			background: #0b0b0b;
			color: white;
			margin: 0;
			padding: 0;
			font-family: Arial, Helvetica, sans-serif;
		}

		/* =========================
   HEADER
========================= */

		.album-header {
			text-align: center;
			padding: 40px 20px;
		}

		.album-header h1 {
			font-size: clamp(30px, 5vw, 55px);
			margin-bottom: 10px;
		}

		.album-header h2 {
			color: #aaa;
			font-weight: 300;
		}

		/* =========================
   ZOOM COVER
========================= */

		.album-header h2 {
			cursor: pointer;
			transition: 0.3s;
		}

		.album-header h2:hover {
			transform: scale(1.05);
			color: #1db954;
		}

		.cover-modal {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.95);
			display: none;
			justify-content: center;
			align-items: center;
			z-index: 99999;
			backdrop-filter: blur(8px);
			animation: fadeIn 0.3s ease;
		}

		.cover-modal img {
			max-width: 90%;
			max-height: 90vh;
			border-radius: 20px;
			box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
			animation: zoomCover 0.3s ease;
			object-fit: cover;
		}

		.close-cover {
			position: absolute;
			top: 20px;
			right: 30px;
			font-size: 35px;
			color: white;
			cursor: pointer;
			z-index: 2;
			transition: 0.3s;
		}

		.close-cover:hover {
			color: #1db954;
			transform: scale(1.2);
		}

		@keyframes zoomCover {
			from {
				transform: scale(0.7);
				opacity: 0;
			}
			to {
				transform: scale(1);
				opacity: 1;
			}
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
			}
			to {
				opacity: 1;
			}
		}

		/* =========================
   GLOBAL PLAYER
========================= */

		.global-player {
			position: sticky;
			top: 0;
			z-index: 999;
			background: #111;
			border-bottom: 1px solid #222;
			padding: 15px;
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: center;
			gap: 15px;
		}

		.global-player button {
			background: #1db954;
			border: none;
			color: white;
			width: 50px;
			height: 50px;
			border-radius: 50%;
			cursor: pointer;
			font-size: 20px;
			transition: 0.3s;
		}

		.global-player button:hover {
			transform: scale(1.1);
		}

		.now-playing {
			font-size: 16px;
			color: #fff;
			min-width: 200px;
			text-align: center;
		}

		#main-player {
			width: 100%;
			max-width: 500px;
		}

		/* =========================
   GRID
========================= */

		.album-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			gap: 30px;
			padding: 30px;
			max-width: 1400px;
			margin: auto;
		}

		/* =========================
   CARD
========================= */

		.music-card {
			background: #111;
			border-radius: 20px;
			padding: 20px;
			text-align: center;
			transition: 0.3s;
			box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
		}

		.music-card:hover {
			transform: translateY(-5px);
		}

		/* =========================
   CD
========================= */

		.cd-wrapper {
			width: 220px;
			height: 220px;
			margin: auto;
		}

		.cd-disc {
			width: 100%;
			height: 100%;
			border-radius: 50%;
			overflow: hidden;
			position: relative;
			background: black;
			box-shadow: 0 0 20px rgba(0, 0, 0, 0.6), inset 0 0 15px rgba(255, 255, 255, 0.1);
		}

		.cd-disc.playing {
			animation: spin 5s linear infinite;
		}

		.cd-disc img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			border-radius: 50%;
		}

		.cd-disc::after {
			content: "";
			position: absolute;
			top: 50%;
			left: 50%;
			width: 40px;
			height: 40px;
			transform: translate(-50%, -50%);
			background: #111;
			border: 5px solid #444;
			border-radius: 50%;
		}

		/* =========================
   TEXT
========================= */

		.music-title {
			margin-top: 20px;
			font-size: 22px;
			font-weight: bold;
		}

		.music-artist {
			color: #aaa;
			margin-top: 5px;
			margin-bottom: 15px;
		}

		/* =========================
   BUTTON
========================= */

		.play-btn {
			background: #1db954;
			color: white;
			border: none;
			padding: 10px 18px;
			border-radius: 30px;
			cursor: pointer;
			transition: 0.3s;
		}

		.play-btn:hover {
			background: #18a349;
		}

		.locked-btn {
			background: #444;
		}

		.locked-btn:hover {
			background: #555;
		}

		/* =========================
   RESPONSIVE
========================= */

		@media(max-width:768px) {

			.cd-wrapper {
				width: 180px;
				height: 180px;
			}

			.album-grid {
				padding: 15px;
			}

		}

		/* =========================
   SPIN
========================= */

		@keyframes spin {
			from {
				transform: rotate(0deg);
			}
			to {
				transform: rotate(360deg);
			}
		}

		/* =========================
   LYRICS BUTTON
========================= */

		.lyrics-btn {
			margin-top: 12px;
			background: #222;
			border: none;
			color: white;
			width: 45px;
			height: 45px;
			border-radius: 50%;
			cursor: pointer;
			font-size: 20px;
			transition: 0.3s;
		}

		.lyrics-btn:hover {
			background: #1db954;
			transform: scale(1.1);
		}

		.lyrics-text {
			white-space: pre-line;
			line-height: 1.8;
			color: #ddd;
			font-size: 18px;

			/* anti copie */
			user-select: none;
			-webkit-user-select: none;
			-moz-user-select: none;
			-ms-user-select: none;

			-webkit-touch-callout: none;
		}

		/* =========================
   MODAL LYRICS
========================= */

		.lyrics-modal {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.9);
			display: none;
			justify-content: center;
			align-items: center;
			z-index: 5000;
			padding: 20px;
		}

		.lyrics-content {
			background: #111;
			width: min(700px, 95%);
			max-height: 85vh;
			overflow-y: auto;
			border-radius: 20px;
			padding: 30px;
			box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
			position: relative;
			animation: zoomIn 0.3s ease;
		}

		.lyrics-content h2 {
			margin-top: 0;
			margin-bottom: 20px;
			text-align: center;
		}

		.lyrics-text {
			white-space: pre-line;
			line-height: 1.8;
			color: #ddd;
			font-size: 18px;
		}

		.close-lyrics {
			position: absolute;
			top: 15px;
			right: 20px;
			font-size: 28px;
			cursor: pointer;
			color: white;
		}

		.close-lyrics:hover {
			color: #1db954;
		}

		@keyframes zoomIn {
			from {
				transform: scale(0.7);
				opacity: 0;
			}
			to {
				transform: scale(1);
				opacity: 1;
			}
		}

		.music-card.active {
			border: 2px solid #1db954;
			box-shadow: 0 0 25px rgba(29, 185, 84, 0.5);
		}

		.album-header {
			text-align: center;
			padding: 100px 20px;
			position:relative;
			z-index:0;
			overflow:visible;
			background-image: url("{{ coverImage }}");
			background-size: cover;
			background-position: center;
			background-repeat: no-repeat;
			border-radius: 0 0 30px 30px;
		}
		.album-header::before {
			content: "";
			position: absolute;
			inset: 0;
			background: rgba(0, 0, 0, 0.55);
		}
		.album-header h1,
		.album-header h2 {
			position: relative;
			z-index: 2;
			color: white;
		}

		.album-header {
			position: relative;
			z-index: 1;
		}

		.album-header::before {
			z-index: 1;
		}

		.album-header h1,
		.album-header h2,
		.album-header a,
		.album-header div {
			position: relative;
			z-index: 2;
		}
		
		.buy-btn{
			display:inline-block;
			padding:15px 25px;
			background:#1db954;
			color:white;
			text-decoration:none;
			border-radius:12px;
			font-weight:bold;
			transition:.3s;
		}

		.buy-btn:hover{
			transform:scale(1.05);
			background:#18a349;
			color:white;
		}
		
		.repeat-active{
			background:#18a349 !important;
			box-shadow:0 0 15px #dbea0d;
		}

		.zoomable-cover{
			cursor:pointer;
			transition:.3s;
		}

		.zoomable-cover:hover{
			transform:scale(1.03);
			box-shadow:0 0 25px rgba(29,185,84,.4);
		}
		
		.shuffle-active{
			background:#18a349 !important;
			box-shadow:0 0 15px #00d9ff;
		}

		.album-btn{
			margin-left: 10px;
			background:#222;
			color:white;
			border:none;
			width:45px;
			height:45px;
			border-radius:50%;
			cursor:pointer;
			font-size:18px;
			transition:.3s;
		}

		.album-btn:hover{
			background:#1db954;
			transform:scale(1.1);
		}
		
	</style>

	{# =========================
																	   USER STATUS
																	========================= #}

	{# {% set canPlayFull = hasBought %} #}
	{# {% set canPlayFull = hasBought or isFreeTrack %} #}

	{# =========================
																	   HEADER
																	========================= #}
	<div class="album-header">
		<h2>💿 {{ pageTitle }}</h2>
		{% if app.user and not hasBought %}
			<div style="margin-top:20px; position:relative; z-index:2;">
				<a href="{{ path('app_album_buy', {id: album.id}) }}"
				class="btn btn-success">
					🛒 {{ 'music.buy_album'|trans }}
				</a>
			</div>

			{% if purchase is defined and purchase and purchase.invoiceFile %}
				<div style="margin-top:15px;">
					<a href="{{ path('app_invoice_download', {
						id: purchase.id
					}) }}"
					class="buy-btn">
						📄 Télécharger ma facture
					</a>
				</div>
			{% endif %}
		{% endif %}
	</div>

	<div class="cover-modal" id="coverModal">
		<span class="close-cover" id="closeCover">✖</span>
		<img src="{{ coverImage }}" alt="{{ pageTitle }}" id="zoomedCover">
	</div>

	{# =========================
																	   GLOBAL PLAYER
																	========================= #}

	<div class="global-player">

		<button id="prevBtn">⏮</button>

		<button id="playPauseBtn">▶</button>

		<button id="nextBtn">⏭</button>

		<button id="shuffleBtn">🔀</button>

		<button id="repeatBtn">🔂</button>
		<div class="now-playing" id="nowPlaying">
			{{ 'music.no_track'|trans }}
		</div>

		{# <audio id="main-player" controls></audio> #}
		{# <audio id="main-player" controls controlsList="nodownload"></audio> #}
		<audio id="main-player" controls controlslist="nodownload noplaybackrate" disablepictureinpicture></audio>

	</div>


	{# =========================
																				   ALBUM GRID
																				========================= #}

	<div class="album-grid">

		{% for music in musics %}

			{# 
																																																						       RÈGLES :
																																																						       - connecté => accès total
																																																						       - non connecté :
																																																						           * 2 premiers morceaux = complet
																																																						           * reste = seulement 60 secondes
																																																						    #}

			{% set isFreeTrack = loop.index0 < 2 %}
			{% set canPlayFullTrack = hasBought or isFreeTrack %}
			<div class="music-card" id="card-{{ loop.index0 }}">

				<div class="cd-wrapper">

					<div class="cd-disc zoomable-cover"
					id="disc-{{ loop.index0 }}"
					data-image="
					{% if music.coverImage %}
						{{ asset('uploads/images/' ~ music.coverImage) }}
					{% elseif music.album and music.album.coverImage %}
						{{ asset('uploads/albums/' ~ music.album.coverImage) }}
					{% else %}
						{{ asset('images/default-music.jpg') }}
					{% endif %}
					">
						{% if music.coverImage %}
							<img src="{{ asset('uploads/images/' ~ music.coverImage) }}" alt="{{ music.title }}">
						{% elseif music.album and music.album.coverImage %}
							<img src="{{ asset('uploads/albums/' ~ music.album.coverImage) }}" alt="{{ music.title }}">
						{% else %}
							<img src="{{ asset('images/default-music.jpg') }}" alt="default">
						{% endif %}

					</div>

				</div>

				<div class="music-title">
					{{ music.track }} <br> {{ music.title }}
				</div>

				<div class="music-artist">
					{{ music.artist }}
				</div>

				{# <div class="music-views">
					👁
					{{ music.views }}
					{{ 'music.views'|trans }}
				</div> #}

				<button class="play-btn {% if not canPlayFullTrack %}locked-btn{% endif %}"
					data-id="{{ music.id }}"
					data-src="{{ asset('uploads/music/' ~ music.audioFile) }}"
					data-title="{{ music.title }}"
					data-index="{{ loop.index0 }}"
					data-full="{{ canPlayFullTrack ? '1' : '0' }}">

					{% if app.user %}
						▶ {{ 'music.play'|trans }}
					{% else %}
						{% if isFreeTrack %}
							▶ {{ 'music.play'|trans }}
						{% else %}
							<a href="{{ path('app_login', {
								_target_path: app.request.uri
							}) }}">
								🔒 {{ 'music.login_to_listen'|trans }}
							</a>

							{# ---------acheter------------------ #}
							{% if app.user and not hasBought %}
								<div style="margin-top:20px; position:relative; z-index:2;">
									<a href="{{ path('app_album_buy', {id: album.id}) }}"
									class="btn btn-success">
										🛒 {{ 'music.buy_album'|trans }}
									</a>
								</div>

								{% if purchase is defined and purchase and purchase.invoiceFile %}
									<div style="margin-top:15px;">
										<a href="{{ path('app_invoice_download', {
											id: purchase.id
										}) }}"
										class="buy-btn">
											📄 Télécharger ma facture
										</a>
									</div>
								{% endif %}
							{% endif %}
						{% endif %}
					{% endif %}

					
				</button>

				<button class="lyrics-btn" data-lyrics="{{ music.lyrics|e('html_attr') }}" data-title="{{ music.title }}">
					🎤
				</button>

				<button class="album-btn"
					data-image="
					{% if music.coverImage %}
						{{ asset('uploads/images/' ~ music.coverImage) }}
					{% elseif music.album and music.album.coverImage %}
						{{ asset('uploads/albums/' ~ music.album.coverImage) }}
					{% else %}
						{{ asset('images/default-music.jpg') }}
					{% endif %}
				">
					💿
				</button>

			</div>

		{% endfor %}

	</div>

	<div class="lyrics-modal" id="lyricsModal">

		<div class="lyrics-content">

			<span class="close-lyrics" id="closeLyrics">
				✖
			</span>

			<h2 id="lyricsTitle">
				{{ 'music.lyrics'|trans }}
			</h2>

			<div class="lyrics-text"
				id="lyricsText"
				oncontextmenu="return false">
			</div>

		</div>

	</div>

	<script>

const repeatBtn = document.getElementById('repeatBtn');
const shuffleBtn = document.getElementById('shuffleBtn');

let shuffleMode = false;
let repeatMode = false;

		const player = document.getElementById('main-player');
const playPauseBtn = document.getElementById('playPauseBtn');
const nextBtn = document.getElementById('nextBtn');
const prevBtn = document.getElementById('prevBtn');
const nowPlaying = document.getElementById('nowPlaying');

const tracks = document.querySelectorAll('.play-btn');

let currentIndex = 0;

/* =========================
   REPEAT MODE
========================= */

repeatBtn.addEventListener('click', () => {

	repeatMode = !repeatMode;

	// repeat natif HTML5
	player.loop = repeatMode;

	if(repeatMode){

		repeatBtn.classList.add('repeat-active');

	}else{

		repeatBtn.classList.remove('repeat-active');

	}

});

/* =========================
   LOAD TRACK
========================= */

function loadTrack(index) {

const track = tracks[index];

player.src = track.dataset.src;

nowPlaying.innerHTML = "🎵 " + track.dataset.title;

currentIndex = index;

updateDiscs();

scrollToCurrentCard();

}

/* =========================
   AUTO SCROLL ACTIVE CARD
========================= */

function scrollToCurrentCard() { // retire ancienne active
document.querySelectorAll('.music-card').forEach(card => {
card.classList.remove('active');
});

// récupère la card actuelle
const activeCard = document.getElementById('card-' + currentIndex);

if (activeCard) { // active style
activeCard.classList.add('active');

// scroll vers la card
activeCard.scrollIntoView({behavior: 'smooth', block: 'center'});

}

}

/* =========================
   PLAY TRACK
========================= */

tracks.forEach(track => {

track.addEventListener('click', () => {

currentIndex = parseInt(track.dataset.index);

loadTrack(currentIndex);

player.play();

});

});

/* =========================
   PLAY / PAUSE
========================= */

playPauseBtn.addEventListener('click', () => {

if (player.paused) {

player.play();

} else {

player.pause();

}

});

/* =========================
   PLAYER EVENTS
========================= */

player.addEventListener('play', () => {

playPauseBtn.innerHTML = '⏸';

updateDiscs(true);

});

player.addEventListener('pause', () => {

playPauseBtn.innerHTML = '▶';

updateDiscs(false);

});

/* =========================
   LIMIT 60s FOR GUESTS
========================= */

player.addEventListener('timeupdate', () => {

const currentTrack = tracks[currentIndex];
const musicId = currentTrack.dataset.id;

// compter une seule vue
if (player.currentTime >= 5 && !viewedTracks.includes(musicId)) {

viewedTracks.push(musicId);

fetch('/music/' + musicId + '/view', {method: 'POST'});
}

const fullAccess = currentTrack.dataset.full === "1";

if (!fullAccess && player.currentTime >= 60) {
    player.pause();

    const isLogged = {{ app.user ? 'true' : 'false' }};

    if (!isLogged) {
        window.location.href =
		"{{ path('app_login') }}?_target_path=" +
		encodeURIComponent(window.location.pathname + window.location.search);
    } else {
        if (confirm("{{ 'music.confirm_buy'|trans }}\n {{ 'music.confirm_buy2'|trans|lower }}")) {
            window.location.href = "{{ path('app_album_buy', {id: album.id}) }}";
        }
    }
}

});

/* =========================
   NEXT
========================= */

nextBtn.addEventListener('click', () => {

if(shuffleMode){

	currentIndex = getRandomTrackIndex();

}else{

	currentIndex++;

	if (currentIndex >= tracks.length) {
		currentIndex = 0;
	}

}

loadTrack(currentIndex);

player.play();

});

/* =========================
   PREV
========================= */

prevBtn.addEventListener('click', () => {

currentIndex--;

if (currentIndex < 0) {
currentIndex = tracks.length - 1;
}

loadTrack(currentIndex);

player.play();

});

/* =========================
   AUTO NEXT
========================= */

player.addEventListener('ended', () => {


	// musique suivante
	if(shuffleMode){

		currentIndex = getRandomTrackIndex();

	}else{

		currentIndex++;

		if(currentIndex >= tracks.length){
			currentIndex = 0;
		}

	}

	loadTrack(currentIndex);

	player.play();

});

/* =========================
   DISC ANIMATION
========================= */

function updateDiscs(play = false) {

document.querySelectorAll('.cd-disc').forEach(disc => {
disc.classList.remove('playing');
});

if (play) {

const activeDisc = document.getElementById('disc-' + currentIndex);

if (activeDisc) {
activeDisc.classList.add('playing');
}

}

}

/* =========================
   INIT
========================= */

if (tracks.length > 0) {
loadTrack(0);
}

/* =========================
   LYRICS MODAL
========================= */

const lyricsButtons = document.querySelectorAll('.lyrics-btn');

const lyricsModal = document.getElementById('lyricsModal');

const lyricsText = document.getElementById('lyricsText');

const lyricsTitle = document.getElementById('lyricsTitle');

const closeLyrics = document.getElementById('closeLyrics');

lyricsButtons.forEach(btn => {

btn.addEventListener('click', () => {

lyricsTitle.innerHTML = "🎤 " + btn.dataset.title;

lyricsText.innerHTML = btn.dataset.lyrics
    ? btn.dataset.lyrics
    : "{{ 'music.no_lyrics'|trans }}";
lyricsModal.style.display = 'flex';

});

});

/* CLOSE */

closeLyrics.addEventListener('click', () => {

lyricsModal.style.display = 'none';

});

lyricsModal.addEventListener('click', (e) => {

if (e.target === lyricsModal) {

lyricsModal.style.display = 'none';

}

});

let viewedTracks = [];

/* =========================
   COVER ZOOM
========================= */

const albumTitle = document.querySelector('.album-header h2');

const coverModal = document.getElementById('coverModal');

const closeCover = document.getElementById('closeCover');

albumTitle.addEventListener('click', () => {

	coverModal.style.display = 'flex';

});

/* CLOSE */

closeCover.addEventListener('click', () => {

	coverModal.style.display = 'none';

});

coverModal.addEventListener('click', (e) => {

	if (e.target === coverModal) {

		coverModal.style.display = 'none';

	}

});

/* =========================
   BLOCK COPY LYRICS
========================= */

lyricsText.addEventListener('copy', (e) => {
	e.preventDefault();
});

lyricsText.addEventListener('cut', (e) => {
	e.preventDefault();
});

lyricsText.addEventListener('contextmenu', (e) => {
	e.preventDefault();
});

lyricsText.addEventListener('selectstart', (e) => {
	e.preventDefault();
});

lyricsText.addEventListener('dragstart', (e) => {
	e.preventDefault();
});

document.addEventListener('keydown', (e) => {

	// Ctrl+C
	if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'c') {

		if (lyricsModal.style.display === 'flex') {
			e.preventDefault();
		}
	}

});

/* =========================
   BUTTON ALBUM ZOOM
========================= */

const zoomedCover = document.getElementById('zoomedCover');

const albumButtons = document.querySelectorAll('.album-btn');

albumButtons.forEach(btn => {

	btn.addEventListener('click', () => {

		const image = btn.dataset.image;

		zoomedCover.src = image;

		coverModal.style.display = 'flex';

	});

});


