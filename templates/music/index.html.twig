shuffleBtn.addEventListener('click', () => {

	shuffleMode = !shuffleMode;

	if(shuffleMode){

		shuffleBtn.classList.add('shuffle-active');

	}else{

		shuffleBtn.classList.remove('shuffle-active');

	}

});

