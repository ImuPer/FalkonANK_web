{# templates/music/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}🎵 Album -
	{{ product.name }}
{% endblock %}

{% block body %}

	<style>

		body {
			background: #0b0b0b;
			color: white;
			margin: 0;
			padding: 0;
			font-family: Arial, Helvetica, sans-serif;
		}

		/* =========================
   HEADER
========================= */

		.album-header {
			text-align: center;
			padding: 40px 20px;
		}

		.album-header h1 {
			font-size: clamp(30px, 5vw, 55px);
			margin-bottom: 10px;
		}

		.album-header h2 {
			color: #aaa;
			font-weight: 300;
		}

		/* =========================
   GLOBAL PLAYER
========================= */

		.global-player {
			position: sticky;
			top: 0;
			z-index: 999;
			background: #111;
			border-bottom: 1px solid #222;
			padding: 15px;
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: center;
			gap: 15px;
		}

		.global-player button {
			background: #1db954;
			border: none;
			color: white;
			width: 50px;
			height: 50px;
			border-radius: 50%;
			cursor: pointer;
			font-size: 20px;
			transition: 0.3s;
		}

		.global-player button:hover {
			transform: scale(1.1);
		}

		.now-playing {
			font-size: 16px;
			color: #fff;
			min-width: 200px;
			text-align: center;
		}

		#main-player {
			width: 100%;
			max-width: 500px;
		}

		/* =========================
   GRID
========================= */

		.album-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			gap: 30px;
			padding: 30px;
			max-width: 1400px;
			margin: auto;
		}

		/* =========================
   CARD
========================= */

		.music-card {
			background: #111;
			border-radius: 20px;
			padding: 20px;
			text-align: center;
			transition: 0.3s;
			box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
		}

		.music-card:hover {
			transform: translateY(-5px);
		}

		/* =========================
   CD
========================= */

		.cd-wrapper {
			width: 220px;
			height: 220px;
			margin: auto;
		}

		.cd-disc {
			width: 100%;
			height: 100%;
			border-radius: 50%;
			overflow: hidden;
			position: relative;
			background: black;
			box-shadow: 0 0 20px rgba(0, 0, 0, 0.6), inset 0 0 15px rgba(255, 255, 255, 0.1);
		}

		.cd-disc.playing {
			animation: spin 5s linear infinite;
		}

		.cd-disc img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			border-radius: 50%;
		}

		.cd-disc::after {
			content: "";
			position: absolute;
			top: 50%;
			left: 50%;
			width: 40px;
			height: 40px;
			transform: translate(-50%, -50%);
			background: #111;
			border: 5px solid #444;
			border-radius: 50%;
		}

		/* =========================
   TEXT
========================= */

		.music-title {
			margin-top: 20px;
			font-size: 22px;
			font-weight: bold;
		}

		.music-artist {
			color: #aaa;
			margin-top: 5px;
			margin-bottom: 15px;
		}

		/* =========================
   BUTTON
========================= */

		.play-btn {
			background: #1db954;
			color: white;
			border: none;
			padding: 10px 18px;
			border-radius: 30px;
			cursor: pointer;
			transition: 0.3s;
		}

		.play-btn:hover {
			background: #18a349;
		}

		.locked-btn {
			background: #444;
		}

		.locked-btn:hover {
			background: #555;
		}

		/* =========================
   RESPONSIVE
========================= */

		@media(max-width:768px) {

			.cd-wrapper {
				width: 180px;
				height: 180px;
			}

			.album-grid {
				padding: 15px;
			}

		}

		/* =========================
   SPIN
========================= */

		@keyframes spin {
			from {
				transform: rotate(0deg);
			}
			to {
				transform: rotate(360deg);
			}
		}

		/* =========================
   LYRICS BUTTON
========================= */

		.lyrics-btn {
			margin-top: 12px;
			background: #222;
			border: none;
			color: white;
			width: 45px;
			height: 45px;
			border-radius: 50%;
			cursor: pointer;
			font-size: 20px;
			transition: 0.3s;
		}

		.lyrics-btn:hover {
			background: #1db954;
			transform: scale(1.1);
		}

		/* =========================
   MODAL LYRICS
========================= */

		.lyrics-modal {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.9);
			display: none;
			justify-content: center;
			align-items: center;
			z-index: 5000;
			padding: 20px;
		}

		.lyrics-content {
			background: #111;
			width: min(700px, 95%);
			max-height: 85vh;
			overflow-y: auto;
			border-radius: 20px;
			padding: 30px;
			box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
			position: relative;
			animation: zoomIn 0.3s ease;
		}

		.lyrics-content h2 {
			margin-top: 0;
			margin-bottom: 20px;
			text-align: center;
		}

		.lyrics-text {
			white-space: pre-line;
			line-height: 1.8;
			color: #ddd;
			font-size: 18px;
		}

		.close-lyrics {
			position: absolute;
			top: 15px;
			right: 20px;
			font-size: 28px;
			cursor: pointer;
			color: white;
		}

		.close-lyrics:hover {
			color: #1db954;
		}

		@keyframes zoomIn {
			from {
				transform: scale(0.7);
				opacity: 0;
			}
			to {
				transform: scale(1);
				opacity: 1;
			}
		}

		.music-card.active {
			border: 2px solid #1db954;
			box-shadow: 0 0 25px rgba(29, 185, 84, 0.5);
		}
	</style>

	{# =========================
					   USER STATUS
					========================= #}

	{% set isLoggedIn = app.user ? true : false %}

	{# =========================
					   GLOBAL PLAYER
					========================= #}

	<div class="global-player">

		<button id="prevBtn">⏮</button>

		<button id="playPauseBtn">▶</button>

		<button id="nextBtn">⏭</button>

		<div class="now-playing" id="nowPlaying">
			Aucun morceau
		</div>

		<audio id="main-player" controls></audio>

	</div>

	{# =========================
					   HEADER
					========================= #}

	<div class="album-header">

		<h1>
			{# 🎵{{ product.name }}</h1> #}

			<h2>💿 Album Musical</h2>

		</div>

		{# =========================
							   ALBUM GRID
							========================= #}

		<div class="album-grid">

			{% for music in musics %}

				{# 
																	       RÈGLES :
																	       - connecté => accès total
																	       - non connecté :
																	           * 2 premiers morceaux = complet
																	           * reste = seulement 60 secondes
																	    #}

				{% set isFreeTrack = loop.index0 < 2 %}
				{% set canPlayFull = isLoggedIn or isFreeTrack %}

				<div class="music-card" id="card-{{ loop.index0 }}">

					<div class="cd-wrapper">

						<div class="cd-disc" id="disc-{{ loop.index0 }}">

							{% if music.coverImage %}
								<img src="{{ asset('uploads/images/' ~ music.coverImage) }}" alt="{{ music.title }}">
							{% else %}
								<img src="{{ asset('images/default-music.jpg') }}" alt="default">
							{% endif %}

						</div>

					</div>

					<div class="music-title">
						{{ music.title }}
					</div>

					<div class="music-artist">
						{{ music.artist }}
					</div>

					<button class="play-btn {% if not canPlayFull %}locked-btn{% endif %}" data-src="{{ asset('uploads/music/' ~ music.audioFile) }}" data-title="{{ music.title }}" data-index="{{ loop.index0 }}" data-full="{{ canPlayFull ? '1' : '0' }}">

						{% if canPlayFull %}
							▶ Lire
						{% else %}
							<a href="{{ path('app_login', {'id': product.id}) }}">
								🔒 Connecte-toi
							</a>
						{% endif %}

					</button>

					<button class="lyrics-btn" data-lyrics="{{ music.lyrics|e('html_attr') }}" data-title="{{ music.title }}">
						🎤
					</button>

				</div>

			{% endfor %}

		</div>

		<div class="lyrics-modal" id="lyricsModal">

			<div class="lyrics-content">

				<span class="close-lyrics" id="closeLyrics">
					✖
				</span>

				<h2 id="lyricsTitle">
					Lyrics
				</h2>

				<div class="lyrics-text" id="lyricsText"></div>

			</div>

		</div>

		<script>

			const player = document.getElementById('main-player');
const playPauseBtn = document.getElementById('playPauseBtn');
const nextBtn = document.getElementById('nextBtn');
const prevBtn = document.getElementById('prevBtn');
const nowPlaying = document.getElementById('nowPlaying');

const tracks = document.querySelectorAll('.play-btn');

let currentIndex = 0;

/* =========================
   LOAD TRACK
========================= */

function loadTrack(index) {

const track = tracks[index];

player.src = track.dataset.src;

nowPlaying.innerHTML = "🎵 " + track.dataset.title;

currentIndex = index;

updateDiscs();

/* =========================
   AUTO SCROLL ACTIVE CARD
========================= */

function scrollToCurrentCard() { // retire ancienne active
document.querySelectorAll('.music-card').forEach(card => {
card.classList.remove('active');
});

// card actuelle
const activeCard = document.getElementById('card-' + currentIndex);

if (activeCard) { // ajoute style active
activeCard.classList.add('active');

// scroll smooth
activeCard.scrollIntoView({behavior: 'smooth', block: 'center'});

}

}

}

/* =========================
   PLAY TRACK
========================= */

tracks.forEach(track => {

track.addEventListener('click', () => {

currentIndex = parseInt(track.dataset.index);

loadTrack(currentIndex);

player.play();

});

});

/* =========================
   PLAY / PAUSE
========================= */

playPauseBtn.addEventListener('click', () => {

if (player.paused) {

player.play();

} else {

player.pause();

}

});

/* =========================
   PLAYER EVENTS
========================= */

player.addEventListener('play', () => {

playPauseBtn.innerHTML = '⏸';

updateDiscs(true);

});

player.addEventListener('pause', () => {

playPauseBtn.innerHTML = '▶';

updateDiscs(false);

});

/* =========================
   LIMIT 60s FOR GUESTS
========================= */

player.addEventListener('timeupdate', () => {

const currentTrack = tracks[currentIndex];

const fullAccess = currentTrack.dataset.full === "1";

// si pas connecté ET morceau premium
if (! fullAccess && player.currentTime >= 60) {

player.pause();

alert("🔒 Connecte-toi pour écouter la musique complète.");

}

});

/* =========================
   NEXT
========================= */

nextBtn.addEventListener('click', () => {

currentIndex++;

if (currentIndex >= tracks.length) {
currentIndex = 0;
}

loadTrack(currentIndex);

player.play();

});

/* =========================
   PREV
========================= */

prevBtn.addEventListener('click', () => {

currentIndex--;

if (currentIndex < 0) {
currentIndex = tracks.length - 1;
}

loadTrack(currentIndex);

player.play();

});

/* =========================
   AUTO NEXT
========================= */

player.addEventListener('ended', () => {

currentIndex++;

if (currentIndex >= tracks.length) {
currentIndex = 0;
}

loadTrack(currentIndex);

player.play();

});

/* =========================
   DISC ANIMATION
========================= */

function updateDiscs(play = false) {

document.querySelectorAll('.cd-disc').forEach(disc => {
disc.classList.remove('playing');
});

if (play) {

const activeDisc = document.getElementById('disc-' + currentIndex);

if (activeDisc) {
activeDisc.classList.add('playing');
}

}

}

/* =========================
   INIT
========================= */

if (tracks.length > 0) {
loadTrack(0);
}

/* =========================
   LYRICS MODAL
========================= */

const lyricsButtons = document.querySelectorAll('.lyrics-btn');

const lyricsModal = document.getElementById('lyricsModal');

const lyricsText = document.getElementById('lyricsText');

const lyricsTitle = document.getElementById('lyricsTitle');

const closeLyrics = document.getElementById('closeLyrics');

lyricsButtons.forEach(btn => {

btn.addEventListener('click', () => {

lyricsTitle.innerHTML = "🎤 " + btn.dataset.title;

lyricsText.innerHTML = btn.dataset.lyrics ? btn.dataset.lyrics : "Aucune parole disponible.";

lyricsModal.style.display = 'flex';

});

});

/* CLOSE */

closeLyrics.addEventListener('click', () => {

lyricsModal.style.display = 'none';

});

lyricsModal.addEventListener('click', (e) => {

if (e.target === lyricsModal) {

lyricsModal.style.display = 'none';

}

});
		</script>

	{% endblock %}
