<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ 'purchase_invoice.title'|trans }}</title>

    <style>
        body{
            font-family: DejaVu Sans, sans-serif;
            color:#333;
            padding:30px;
        }

        .header{
            text-align:center;
            margin-bottom:30px;
        }

        .cover{
            text-align:center;
            margin-bottom:20px;
        }

        .cover img{
            width:150px;
            border-radius:10px;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        th{
            background:#f5f5f5;
            border:1px solid #ddd;
            padding:10px;
        }

        td{
            border:1px solid #ddd;
            padding:10px;
        }

        .total{
            text-align:right;
            margin-top:20px;
            font-size:18px;
            font-weight:bold;
        }

        .footer{
            margin-top:40px;
            text-align:center;
            color:#777;
            font-size:12px;
        }
    </style>
</head>

<body>

<div class="header">
    <h1>{{ 'purchase_invoice.invoice'|trans }}</h1>
    <h3>{{ 'purchase_invoice.number'|trans }} {{ purchase.invoiceNumber }}</h3>
</div>

<div class="cover">
    <img src="https://falkon.click/image/FalkonANK/logo-transparent-png.png" style="max-width:20px;">
</div>

<p>
    <strong>{{ 'purchase_invoice.client'|trans }} :</strong>
    {{ user.firstName }} {{ user.lastName }}
</p>

<p>
    <strong>{{ 'purchase_invoice.email'|trans }} :</strong>
    {{ user.email }}
</p>

<p>
    <strong>{{ 'purchase_invoice.date'|trans }} :</strong>
    {{ purchase.purchaseDate|date('d/m/Y H:i') }}
</p>

<table>
    <thead>
        <tr>
            <th>{{ 'purchase_invoice.album'|trans }}</th>
            <th>{{ 'purchase_invoice.label'|trans }}</th>
            <th>{{ 'purchase_invoice.release_date'|trans }}</th>
            <th>{{ 'purchase_invoice.price'|trans }}</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td>{{ album.name }}</td>
            <td>{{ album.recordLabel }}</td>
            <td>{{ album.releaseDate|date('d/m/Y') }}</td>
            <td>{{ album.price / 100 }} €</td>
        </tr>
    </tbody>
</table>

<div class="total">
    {{ 'purchase_invoice.total'|trans }} : {{ album.price / 100 }} €
</div>

<div class="footer">
    {{ 'music.confirm_buy2'|trans }} <br>
    {{ 'purchase_invoice.thanks'|trans }} <br>
        FalkonANK
</div>

</body>
</html>