<!DOCTYPE html>

<html>
<head>
    <meta charset="UTF-8">
    <title>Facture Achat Album</title>

```
<style>
    body{
        font-family: DejaVu Sans, sans-serif;
        color:#333;
        padding:30px;
    }

    .header{
        text-align:center;
        margin-bottom:30px;
    }

    .cover{
        text-align:center;
        margin-bottom:20px;
    }

    .cover img{
        width:150px;
        border-radius:10px;
    }

    table{
        width:100%;
        border-collapse:collapse;
        margin-top:20px;
    }

    th{
        background:#f5f5f5;
        border:1px solid #ddd;
        padding:10px;
    }

    td{
        border:1px solid #ddd;
        padding:10px;
    }

    .total{
        text-align:right;
        margin-top:20px;
        font-size:18px;
        font-weight:bold;
    }

    .footer{
        margin-top:40px;
        text-align:center;
        color:#777;
        font-size:12px;
    }
</style>
```

</head>
<body>

<div class="header">
    <h1>FACTURE</h1>
    <h3>N° {{ purchase.invoiceNumber }}</h3>
</div>

<div class="cover">
    {% if album.coverImage %}
        <img src="{{ absolute_url(asset('uploads/albums/' ~ album.coverImage)) }}">
    {% endif %}
</div>

<p>
    <strong>Client :</strong>
    {{ user.firstName }} {{ user.lastName }}
</p>

<p>
    <strong>Email :</strong>
    {{ user.email }}
</p>

<p>
    <strong>Date :</strong>
    {{ purchaseDate|date('d/m/Y H:i') }}
</p>

<table>
    <thead>
        <tr>
            <th>Album</th>
            <th>Label</th>
            <th>Date de sortie</th>
            <th>Prix</th>
        </tr>
    </thead>

```
<tbody>
    <tr>
        <td>{{ album.name }}</td>
        <td>{{ album.recordLabel }}</td>
        <td>{{ album.releaseDate|date('d/m/Y') }}</td>
        <td>{{ album.price }} €</td>
    </tr>
</tbody>
```

</table>

<div class="total">
    Total payé : {{ album.price }} €
</div>

<div class="footer">
    Merci pour votre achat.
</div>

</body>
</html>
