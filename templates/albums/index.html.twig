{% extends 'base.html.twig' %}
{% block title %}
	{{ 'albums.title'|trans }}
{% endblock %}
{% block body %}
	<div	class="album-page">
		<div	class="header">
			<h1>
				💿
				{{ 'albums.all_albums'|trans }}
			</h1>
			<p>
				{{ 'albums.discover_collection'|trans }}
			</p>
		</div>
		<div	class="albums-grid">
			{% for album in albums %}
				<a	href="{{ path('app_music_by_album', {
						'id': album.id,
						'_locale': app.request.locale
					}) }}"	class="album-link">
							<div	class="album-card">
								<div	class="disc-container">
									{% if album.coverImage %}
										<img
										src="{{ asset('uploads/albums/' ~ album.coverImage) }}"	alt="{{ album.name }}"	class="album-disc">
											{% else %}
											<div	class="album-disc placeholder">
												🎵
											</div>
										{% endif %}
									</div>
									<div	class="album-content">
										<h2>
											{{ album.name }}
										</h2>
										<div
											class="info-icon"
											onclick="openAlbumModal(event, this)"
											data-name="{{ album.name }}"
											data-description="{{ album.description|e('html_attr') }}"
											data-label="{{ album.recordLabel }}"
											data-date="{{ album.releaseDate|date('d/m/Y') }}"
										>
											ℹ️
										</div>
									</div>
								</div>
					</a>
				{% else %}
					<div	class="empty-state">
						<p>
							{{ 'albums.no_album'|trans }}
						</p>
					</div>
				{% endfor %}
			</div>
		</div>
		<style>

		* {
			box-sizing: border-box;
		}

		body {
			margin: 0;
			background: #0f172a;
			font-family: 'Poppins', sans-serif;
			color: white;
		}

		.album-page {
			padding: 50px 30px;
			min-height: 100vh;
		}

		.header {
			text-align: center;
			margin-bottom: 25px;
		}

		.header h1 {
			font-size: 1rem;
			margin-bottom: 5px;
			font-weight: 350;
		}

		.header p {
			color: #94a3b8;
			font-size: 1.1rem;
		}

		.albums-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
			gap: 15px;
		}

		.album-card {
			padding: 15px 12px;
			border-radius: 18px;
		}

		.disc-container {
			margin-bottom: 10px;
		}

		.album-disc {
			width: 120px;
			height: 120px;
			border: 5px solid #111827;
			box-shadow: 0 0 0 5px #1e293b, 0 8px 15px rgba(0, 0, 0, 0.4);
		}

		.album-content h2 {
			font-size: 1rem;
			margin: 5px 0;
			line-height: 1.3;
		}

		.info-icon {
			width: 28px;
			height: 28px;
			font-size: 0.9rem;
			top: 8px;
			right: 8px;
		}

		.album-card:hover {
			transform: translateY(-4px);
		}

		.disc-container {
			position: relative;
			display: flex;
			justify-content: center;
			margin-bottom: 25px;
		}

		.album-disc {
			width: 180px;
			height: 180px;
			border-radius: 50%;
			object-fit: cover;
			border: 8px solid #111827;
			box-shadow: 0 0 0 8px #1e293b, 0 15px 30px rgba(0, 0, 0, 0.5);
			transition: 0.5s ease;
		}

		.album-card:hover .album-disc {
			transform: rotate(10deg) scale(1.05);
		}

		.placeholder {
			display: flex;
			align-items: center;
			justify-content: center;
			background: #1e293b;
			font-size: 4rem;
		}

		.album-content {
			color: #f0d50a;
			text-align: center;
		}

		.album-content h2 {
			font-size: 1.5rem;
			margin-bottom: 15px;
			font-weight: 600;
		}

		.album-info {
			color: #cbd5e1;
			margin-bottom: 10px;
			font-size: 0.95rem;
		}

		.album-date {
			color: #94a3b8;
			font-size: 0.9rem;
		}

		.empty-state {
			grid-column: 1/-1;
			text-align: center;
			padding: 50px;
			background: rgba(255, 255, 255, 0.05);
			border-radius: 20px;
		}

		
		.info-icon {
			position: absolute;
			top: 0;
			right: 20px; /* ajuste selon l'effet voulu */
			z-index: 10;

			width: 36px;
			height: 36px;

			display: flex;
			align-items: center;
			justify-content: center;

			border-radius: 50%;
			background: rgba(255,255,255,.15);
			cursor: pointer;
			transition: .3s;
		}

		.info-icon:hover {
			background: #f0d50a;
			transform: scale(1.1);
		}

		@media(max-width:768px) {

			.header h1 {
				font-size: 1rem;
			}

			.album-disc {
				width: 90px;
				height: 90px;
			}

			.album-content h2 {
				font-size: 0.5rem;
			}

			.album-card {
				padding: 6px 5px;
			}

			.info-icon {
				width: 10px;
				height: 10px;
				font-size: 0.5rem;
				top: 4px;
				right: 4px;
			}
		}

		

		/* MODAL */
		.modal {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: rgba(0,0,0,0.7);
			display: flex;
			align-items: center;
			justify-content: center;
			z-index: 999;
		}

		.modal.hidden {
			display: none;
		}

		.modal-content {
			background: #1e293b;
			padding: 30px;
			border-radius: 20px;
			width: 90%;
			max-width: 500px;
			text-align: center;
			position: relative;
			color: white;
			box-shadow: 0 20px 60px rgba(0,0,0,0.6);
		}

		.close {
			position: absolute;
			top: 10px;
			right: 15px;
			cursor: pointer;
			font-size: 1.2rem;
		}

		.album-card {
			position: relative;
		}

		.info-icon {
			position: absolute;
			top: 12px;
			right: 12px;
			z-index: 10;
			cursor: pointer;
			width: 36px;
			height: 36px;
			border-radius: 50%;
			background: rgba(255,255,255,.15);
			display: flex;
			align-items: center;
			justify-content: center;
			transition: .3s;
		}

		.info-icon:hover {
			background: #f0d50a;
			transform: scale(1.1);
		}
	</style>	
	{#-----------modal infos----------------------------------- #}
		<div	id="albumModal"	class="modal hidden">
			<div	class="modal-content">
				<span	class="close"	onclick="closeAlbumModal()">
					✖
				</span>
				<h2	id="modalTitle"></h2>
				<p	id="modalDescription"></p>
				<div	class="modal-label">
					📀
					<span	id="modalLabel"></span>
				</div>
				<div	class="modal-date">
					📅
					<span	id="modalDate"></span>
				</div>
			</div>
			<script>
				function openAlbumModal(event, element) {
					event.preventDefault();
					event.stopPropagation();

					document.getElementById('albumModal').classList.remove('hidden');

					document.getElementById('modalTitle').textContent =
						element.dataset.name;

					document.getElementById('modalDescription').innerHTML =
						element.dataset.description;

					document.getElementById('modalLabel').textContent =
						element.dataset.label;

					document.getElementById('modalDate').textContent =
						element.dataset.date;
				}

				function closeAlbumModal() {
					document.getElementById('albumModal').classList.add('hidden');
				}
				</script>
		</div>
	{% endblock %}
	